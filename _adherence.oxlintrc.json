{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": []
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Press Start 2P|VT323))/i]",
        "message": "Font not provided by the design system. Available: Press Start 2P, VT323."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent-cool",
      "--accent-done",
      "--accent-music",
      "--accent-warm",
      "--bg",
      "--bg-2",
      "--bg-3",
      "--divider",
      "--fg",
      "--fg-dim",
      "--fg-muted",
      "--font-body",
      "--font-display",
      "--line",
      "--size-body",
      "--size-hero",
      "--size-label",
      "--size-stat",
      "--surface-card",
      "--text-body",
      "--text-hero",
      "--track-label",
      "--w-bold",
      "--w-medium",
      "--w-regular"
    ],
    "tokenKinds": {
      "--font-display": "font",
      "--font-body": "font",
      "--w-regular": "font",
      "--w-medium": "font",
      "--w-bold": "font",
      "--size-hero": "spacing",
      "--size-body": "spacing",
      "--size-label": "spacing",
      "--size-stat": "spacing",
      "--track-label": "spacing",
      "--bg": "color",
      "--bg-2": "color",
      "--bg-3": "color",
      "--fg": "color",
      "--fg-muted": "color",
      "--fg-dim": "color",
      "--line": "color",
      "--accent-warm": "color",
      "--accent-cool": "color",
      "--accent-music": "color",
      "--accent-done": "color",
      "--text-hero": "font",
      "--text-body": "font",
      "--surface-card": "color",
      "--divider": "color"
    },
    "fontFamilies": [
      "Press Start 2P",
      "VT323"
    ]
  }
}